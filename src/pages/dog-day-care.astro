---
import BaseLayout from '../components/BaseLayout.astro';
const breadcrumbs = [
  { name: 'Home', href: '/' },
  { name: 'Daycare', href: '/dog-day-care' },
];
---
<BaseLayout
  title="Dog Daycare | Evolutionary K9 — Mineral Bluff, GA"
  description="Dog Daycare in the Blue Ridge area. Supervised play, monitored personalities and activity levels, plenty of rest. 8am–6pm daily."
  ogImage="/images/daycare.jpg"
  breadcrumbs={breadcrumbs}
>
  <div class="service-hero">
    <img src="/images/daycare.jpg" alt="Jack Russell terrier playing with a chew toy in the grass" width="1900" height="1267" />
  </div>
  <section class="service-hero-title">
    <h1>Dog Daycare</h1>
  </section>

  <section class="section">
    <div class="container-narrow prose">
      <p>We are excited to offer Dog Daycare in the Blue Ridge area because exercising your dog both mentally and physically helps him/her become a happier, more balanced member of your family.</p>

      <p>All of our dogs are supervised during play and we constantly monitor personalities and activity levels. We make sure there is plenty of good quality play time and rest time. Never been to dog daycare? Well give it a try!</p>

      <div class="note-callout">Please note: if it's your dog's first day with us, a one-time First Day / Acclimation Fee of <strong>$15</strong> will be added for processing paperwork and a one-on-one assessment with our team.</div>

      <h2>Daycare Rates</h2>
      <ul class="rate-list">
        <li><span>1 dog</span><strong>$30 per day</strong></li>
        <li><span>2 dogs</span><strong>$60 per day</strong></li>
        <li><span>3 dogs</span><strong>$90 per day</strong></li>
      </ul>

      <h2>Operating Hours</h2>
      <ul class="rate-list">
        <li><span>Drop off</span><strong>8:00 am – 10:00 am</strong></li>
        <li><span>Pick up</span><strong>4:00 pm – 6:00 pm</strong></li>
      </ul>

      <h2>Dog Spa Services</h2>
      <p>We are happy to offer Bubble Bath / Blow Dry and Nail Trim services for our Boarding and Daycare dogs for an additional fee:</p>
      <ul class="rate-list">
        <li><span>Small Dog</span><strong>$30+</strong></li>
        <li><span>Medium Dog</span><strong>$45+</strong></li>
        <li><span>Large Dog</span><strong>$65+</strong></li>
        <li><span>XLarge and/or Long Coat</span><strong>$90+</strong></li>
        <li><span>Nail Trim (per dog)</span><strong>$15</strong></li>
      </ul>

      <p style="text-align: center; margin-top: 36px;">
        <a href={`tel:7707332621`} class="btn">Call to Reserve · 770-733-2621</a>
      </p>
    </div>
  </section>
</BaseLayout>
